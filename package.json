{
  "name": "quacklake",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --config wrangler.example.jsonc --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "smoke:ducklake": "bash scripts/test-ducklake-smoke.sh",
    "smoke:ducklake:r2": "bash scripts/test-ducklake-r2-smoke.sh",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "types": "wrangler types"
  },
  "dependencies": {
    "@polyglot-sql/sdk": "^0.5.1",
    "@quack-protocol/sdk": "^0.2.0",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.14",
    "@cloudflare/workers-types": "4.20260609.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-istanbul": "^4.1.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.99.0"
  }
}
